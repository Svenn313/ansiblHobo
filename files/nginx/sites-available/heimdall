server {
	include snippets/security-headers.conf;
	server_name home.svenlabs.fr heimdall.svenlabs.fr;
	listen [::]:443 ssl ;
        listen 443 ssl ;
    ssl_certificate /etc/letsencrypt/live/svenlabs.fr/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/svenlabs.fr/privkey.pem; # managed by Certbot
        include /etc/letsencrypt/options-ssl-nginx.conf;
        ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

        location / {
            proxy_pass https://127.0.0.1:6040;
            proxy_set_header X-Forwarded-For $remote_addr;
            proxy_set_header X-Forwarded-Proto $scheme;
            include /etc/nginx/proxy_params;
        }




}
