server {
	include snippets/security-headers.conf;
    server_name cadvisor.svenlabs.fr;
    listen [::]:443 ssl;
    listen 443 ssl;

    # SSL configuration
ssl_certificate /etc/letsencrypt/live/svenlabs.fr/fullchain.pem;
ssl_certificate_key /etc/letsencrypt/live/svenlabs.fr/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Limitation de la taille des requêtes pour éviter les attaques par DoS
    client_max_body_size 10M;  # À ajuster selon tes besoins

    location / {
        proxy_pass http://127.0.0.1:7020;
        proxy_http_version 1.1;
        proxy_set_header Connection "upgrade";
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 1d;
    }

    # Restriction d'accès IP
    allow 127.0.0.1; # Permet l'accès depuis localhost
    allow ::1;        # Permet l'accès depuis localhost en IPv6
    allow 192.168.1.0/24;  # Permet l'accès depuis le réseau local
    deny all;         # Refuse toutes les autres connexions
}

