server {
	include snippets/security-headers.conf;
    server_name bbox.svenlabs.fr box.svenlabs.fr;
    if ($host !~* ^(bbox.svenlabs.fr|box.svenlabs.fr)$) {
        return 444;
    }

    include snippets/tls.conf;

	  location / {
    		proxy_pass https://192.168.1.254; # ou l’IP de la box
    		proxy_set_header Host mabbox.bytel.fr;
        include snippets/proxy.conf;
    }
}

