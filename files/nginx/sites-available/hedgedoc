map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
	include snippets/security-headers.conf;
    server_name hedge.svenlabs.fr;
    listen [::]:443 ssl;
    listen 443 ssl;

    # Configuration SSL
    ssl_certificate /etc/letsencrypt/live/svenlabs.fr/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/svenlabs.fr/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    location / {
        proxy_pass http://127.0.0.1:6020;
        proxy_http_version 1.1;
        proxy_set_header Connection "upgrade";
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header X-Forwarded-For $remote_addr;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Host hedge.svenlabs.fr;  # S'assurer que l'en-tête Host est correct
    }

    # Gestion de WebSocket
    location /socket.io {
        proxy_pass http://127.0.0.1:6020;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
    }

    # Optionnel : Limitation de l'accès à certaines adresses IP
    # allow 127.0.0.1;
    # allow ::1;
    # deny all;


}

