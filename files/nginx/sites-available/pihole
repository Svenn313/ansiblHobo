server {
	  server_name pihole.svenlabs.fr;
    include snippets/security-headers.conf;
    include snippets/tls.conf;

    absolute_redirect off;
    proxy_redirect off;

    location = / {
        return 302 /admin/;
    }

    location / {
        proxy_pass http://127.0.0.1:8081;
        include snippets/proxy.conf;
    }
}

