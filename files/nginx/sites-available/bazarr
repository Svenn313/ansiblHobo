server {
	include snippets/security-headers.conf;
    server_name bazarr.svenlabs.fr;
    listen [::]:443 ssl;
    listen 443 ssl;

    # SSL configuration
    ssl_certificate /etc/letsencrypt/live/svenlabs.fr/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/svenlabs.fr/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Limitation de la taille des requêtes pour éviter les attaques par DoS
    client_max_body_size 10M;  # À ajuster selon tes besoins

    location / {
        proxy_pass http://127.0.0.1:8060;
        include /etc/nginx/proxy_params;

        # Sécurisation des en-têtes pour le proxy
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_http_version 1.1;
    }


}

